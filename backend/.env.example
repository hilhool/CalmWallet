GEMINI_API_KEY=your_key_here
DATABASE_URL=postgresql://calmwallet:calmwallet@localhost:5432/calmwallet
# минимум 32 символа: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
PORT=3000
# откуда разрешены CORS-запросы (через запятую для нескольких origins)
CORS_ORIGIN=http://localhost:5173
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Proxy for Gemini API (needed in regions where Google is blocked)
# Common ports: Clash=7890, V2Ray=10809, Shadowsocks=1080
# HTTPS_PROXY=http://127.0.0.1:7890
